<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meu Azul - Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <script>
    window.__INITIAL_CONFIG__ = <%- JSON.stringify(config) %>;
    window.__INITIAL_PROJECTS__ = <%- JSON.stringify(projects) %>;
    window.__INITIAL_MARKETING_TEAM__ = <%- JSON.stringify(marketingTeam) %>;
  </script>
</head>
<body>
  <div class="app-layout">
    <%- include('partials/sidebar', { config: config }) %>

    <main class="main-content">
      <%- include('pages/login') %>
      <%- include('pages/dashboard', { config: config, projects: projects }) %>
      <%- include('pages/novo-projeto', { config: config }) %>
      <%- include('pages/equipe-marketing', { config: config }) %>

      <div id="editModeBar" style="display:none;position:fixed;top:0;left:0;right:0;z-index:9999;background:#003399;color:white;padding:0.5rem 1rem;display:none;align-items:center;gap:0.75rem;box-shadow:0 2px 12px rgba(0,0,0,0.3);">
        <span style="font-weight:700;font-size:0.9rem;">🔧 MODO EDIÇÃO</span>
        <span style="font-size:0.78rem;opacity:0.8;flex:1;">Clique nos textos para editar • Arraste itens para reordenar</span>
        <button class="btn-outline" style="background:rgba(255,255,255,0.15);color:white;border-color:rgba(255,255,255,0.3);padding:0.35rem 1rem;font-size:0.82rem;" onclick="cancelEditMode()">❌ Cancelar</button>
        <button class="btn-primary" style="background:#22c55e;color:white;border:none;padding:0.35rem 1rem;font-size:0.82rem;" onclick="saveInlineEdits()">💾 Aplicar</button>
        <button class="btn-primary" style="background:#f59e0b;color:white;border:none;padding:0.35rem 1rem;font-size:0.82rem;" onclick="devPushNow()">🚀 Push</button>
      </div>
      <div id="editModeNotification" style="display:none;position:fixed;top:60px;left:50%;transform:translateX(-50%);z-index:9999;padding:0.5rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;box-shadow:0 2px 8px rgba(0,0,0,0.15);"></div>
    </main>
  </div>

  <script src="/js/ai-agent.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>