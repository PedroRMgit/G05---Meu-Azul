<div id="page-dashboard" class="page">
  <div class="page-header">
    <h1>Dashboard de Projetos</h1>
    <p class="page-subtitle">Visão geral e análises inteligentes</p>
  </div>
  <div class="stats-bar">
    <div class="stat-card">Total: <span id="totalProjetos">0</span></div>
    <div class="stat-card">Verticais: <span id="totalVerticais">0</span></div>
    <div class="stat-card">Marketing: <span id="totalMarketing">0</span></div>
    <div class="stat-card">Custo Total: <span id="totalCusto">R$ 0</span></div>
    <div class="stat-card">Lucro Total: <span id="totalLucro">R$ 0</span></div>
  </div>
  <div id="notificationArea" class="notification" style="display:none;"></div>
  <div class="section-block">
    <h2>Projetos</h2>
    <div class="projects-list" id="projectsList">
      <% if (projects && projects.length > 0) { %>
        <% projects.forEach(function(p) { %>
          <%- include('../partials/project-card', { project: p }) %>
        <% }); %>
      <% } else { %>
        <p class="empty-state">Nenhum projeto cadastrado. Clique em <strong>"+"</strong> na barra lateral para criar um novo projeto.</p>
      <% } %>
    </div>
  </div>
  <div class="section-block">
    <div class="section-header">
      <h2>Agente de IA - Análise Inteligente</h2>
      <button id="runAnalysisBtn" class="btn-secondary">Executar Análise</button>
    </div>
    <div class="ai-results" id="aiResults">
      <div class="ai-panel">
        <h3>⚡ Conflitos Detectados</h3>
        <div id="conflitosContent"><p class="empty-state">Nenhum conflito detectado ainda.</p></div>
      </div>
      <div class="ai-panel">
        <h3>⏱ Oportunidades de Economia</h3>
        <div id="oportunidadesContent"><p class="empty-state">Nenhuma oportunidade identificada ainda.</p></div>
      </div>
      <div class="ai-panel">
        <h3>📢 Apoio de Marketing</h3>
        <div id="marketingContent"><p class="empty-state">Nenhuma solicitação de marketing.</p></div>
      </div>
      <div class="ai-panel full-width">
        <h3>🏆 Prioridade - Ranking Completo</h3>
        <div id="prioridadeContent"><p class="empty-state">Execute a análise para ver o ranking completo de prioridades.</p></div>
      </div>
      <div class="ai-panel full-width">
        <h3>📋 Resumo dos Projetos</h3>
        <div id="resumosContent"><p class="empty-state">Nenhum resumo disponível.</p></div>
      </div>
    </div>
  </div>
</div>