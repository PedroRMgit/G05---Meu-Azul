<div id="page-equipe-marketing" class="page">
  <div class="page-header">
    <h1>Equipe de Marketing</h1>
    <p class="page-subtitle">Cadastre os membros da equipe de marketing por vertical</p>
  </div>
  <div class="section-block">
    <p style="font-size:0.9rem;color:#666;margin-bottom:1rem;">
      Quando a IA detectar que um projeto precisa de apoio de marketing, ou ranquear o Top 3 projetos com maior potencial de marketing, os emails cadastrados aqui serão notificados automaticamente.
    </p>
    <div class="marketing-form">
      <div class="form-group">
        <label for="mktVertical">Vertical</label>
        <select id="mktVertical">
          <% var vertItems = config.verticals ? config.verticals.items : []; %>
          <% vertItems.forEach(function(v) { %>
            <option value="<%= v.key %>"><%= v.value %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label for="mktNome">Nome</label>
        <input type="text" id="mktNome" placeholder="Ex: Maria Silva">
      </div>
      <div class="form-group">
        <label for="mktEmail">Email</label>
        <input type="email" id="mktEmail" placeholder="maria@azul.com.br">
      </div>
      <div class="form-group" style="align-self:flex-end;">
        <button class="btn-primary" onclick="addMarketingMember()" style="margin-top:0;">Adicionar</button>
      </div>
    </div>
    <div id="marketingTeamList" style="margin-top:1rem;">
      <p class="empty-state">Nenhum membro cadastrado.</p>
    </div>
  </div>
</div>