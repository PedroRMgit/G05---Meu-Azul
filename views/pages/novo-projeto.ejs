<div id="page-novo-projeto" class="page">
  <div class="page-header">
    <h1>Cadastrar Novo Projeto</h1>
    <p class="page-subtitle">Preencha os dados do projeto</p>
  </div>
  <div class="section-block">
    <form id="projectForm">
      <div class="form-grid">
        <div class="form-group">
          <label for="nome">Nome do Projeto *</label>
          <input type="text" id="nome" required placeholder="Ex: Otimização de Rotas">
        </div>
        <div class="form-group">
          <label for="vertical">Vertical *</label>
          <select id="vertical" required>
            <% var vertItems = config.verticals ? config.verticals.items : []; %>
            <% vertItems.forEach(function(v) { %>
              <option value="<%= v.key %>"><%= v.value %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label for="responsavel">Responsável *</label>
          <input type="text" id="responsavel" required placeholder="Ex: João Silva">
        </div>
        <div class="form-group">
          <label for="prazo">Prazo *</label>
          <input type="date" id="prazo" required>
        </div>
        <div class="form-group">
          <label for="custo">Custo (R$)</label>
          <input type="number" id="custo" min="0" step="0.01" placeholder="0,00">
        </div>
        <div class="form-group">
          <label for="lucro">Lucro Estimado (R$)</label>
          <input type="number" id="lucro" min="0" step="0.01" placeholder="0,00">
        </div>
        <div class="form-group">
          <label for="equipe">Tamanho da Equipe</label>
          <input type="number" id="equipe" min="1" value="1">
        </div>
        <div class="form-group full-width">
          <label for="descricao">Descrição do Projeto *</label>
          <textarea id="descricao" required placeholder="Descreva o objetivo, escopo e entregas do projeto..."></textarea>
        </div>
        <div class="form-group full-width" style="margin-top:0.5rem;">
          <div style="font-weight:600;font-size:0.85rem;color:#333;margin-bottom:0.75rem;">
            📊 Critérios de Marketing — <span style="color:#666;font-weight:400;">definidos automaticamente pela IA com base na descrição do projeto</span>
          </div>
          <div id="aiCriteriaPreview" style="display:flex;gap:1rem;flex-wrap:wrap;padding:0.5rem 0.75rem;background:#f0f7ff;border:1px solid #b3d4ff;border-radius:8px;">
            <span style="font-size:0.82rem;color:#003399;">Aguardando descrição para calcular...</span>
          </div>
        </div>
      </div>
      <div class="form-actions">
        <button type="button" class="btn-outline" onclick="navegar('dashboard')">Cancelar</button>
        <button type="submit" class="btn-primary">Cadastrar Projeto</button>
      </div>
    </form>
  </div>
</div>